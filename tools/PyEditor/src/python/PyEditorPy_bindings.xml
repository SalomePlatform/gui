<typesystem package="PyEditorPy">

  <primitive-type name="bool"/>
  <load-typesystem name="typesystem_core.xml" generate="no"/>
  <load-typesystem name="typesystem_gui.xml" generate="no"/>
  <load-typesystem name="typesystem_widgets.xml" generate="no"/>
  <object-type name="PyEditor_Settings" generate="yes">
    <modify-function signature="settings()" static="yes">
      <modify-argument index="return">
          <define-ownership owner="c++"/>
      </modify-argument>
    </modify-function>
    <modify-function signature="setSettings(PyEditor_Settings*)" static="yes">
      <modify-argument index="1">
        <define-ownership owner="c++"/>
      </modify-argument>
    </modify-function>
  </object-type>
  <object-type name="PyEditor_Editor" generate="yes"/>
  <object-type name="PyEditor_FindTool" generate="yes"/>
  <object-type name="PyEditor_Widget" generate="yes"/>

</typesystem>
